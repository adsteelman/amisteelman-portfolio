--- 
import ToTop from "@/components/widgets/ToTop.astro";
import { siteConfig } from "@/config/site.js";
---

<section
  class="text-gray-700 border-t mt-20 md:mt-48 border-dashed border-primary/15 dark:border-primary-dark/15 border-[.75px]"
>
  <div class="container flex flex-col items-center py-8 mx-auto px-7 max-w-7xl text-center">
    <p class="text-sm text-neutral-700 dark:text-neutral-100">
      © {new Date().getFullYear()} {siteConfig.author || "Ami Steelman"}
    </p>
    <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400 max-w-2xl">
      Building practical systems, AI-assisted solutions, and learning experiences that solve real problems.
    </p>
  </div>
</section>

<ToTop />