---
import SectionHeader from "@/components/elements/SectionHeader.astro";
import Matter from "@/components/ui/Matter.astro";
import Button from "@/components/ui/Button.astro";
import systemsAutomation from "@/assets/explore/systems-automation.svg?url";
import toolsApplications from "@/assets/explore/tools-applications.svg?url";
import aiSolutions from "@/assets/explore/ai-solutions.svg?url";
import stemGirls from "@/assets/explore/stem-girls.svg?url";
import justForFun from "@/assets/explore/just-for-fun.svg?url";
interface Props {
  title?: string;
  description?: string;
}
const {title, description
} = Astro.props;

---

<section class="py-8 sm:py-12 md:py-16 md:pb-12 site-container">
    <div class="space-y-6 sm:space-y-8 md:space-y-8">
      <SectionHeader title={title} description={description}/>
    </div>

    <div class="explore-content w-full relative mt-6 sm:mt-8">
        <div class="explore-list w-full relative grid grid-cols-1 md:grid-cols-2 gap-4 max-w-5xl mx-auto">
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-1 h-[220px] sm:h-[240px] md:h-[260px]"
  data-aos="fade-up-sm"
  data-aos-delay="500"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>Systems & Automation</h3>
                        <p>I build systems that reduce chaos and save time.</p>
                        <!-- <div class="mt-2 btn opacity-0 transition duration-300 ease-in-out">
                            <Button type="disabled" url="#" size="sm">
                                Coming Soon
                            </Button>
                        </div> -->
                    </div>
                    <div class="absolute explore-svg explore-svg-1 bottom-0 top-0 w-[45%] pointer-events-none flex items-center">
                        <img src={systemsAutomation} alt="" aria-hidden="true" class="w-full h-auto object-contain">
                    </div>
                </div>
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-2 h-[220px] sm:h-[240px] md:h-[260px]"
  data-aos="fade-up-sm"
  data-aos-delay="600"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>Tools & Applications</h3>
                        <p>I create tools people can actually use.</p>
                    </div>
                    <div class="absolute explore-svg explore-svg-2 bottom-0 top-0 w-[45%] pointer-events-none flex items-center">
                        <img src={toolsApplications} alt="" aria-hidden="true" class="w-full h-auto object-contain">
                    </div>
                </div>
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-3 h-[220px] sm:h-[240px] md:h-[260px]"
  data-aos="fade-up-sm"
  data-aos-delay="700"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>AI-Assisted Solutions</h3>
                        <p>I use AI to extend what’s possible.</p>
                        <div class="mt-2 btn opacity-0 transition duration-300 ease-in-out">
                            <!-- <Button url="/blog" size="sm">
                                Blog
                            </Button> -->
                        </div>
                    </div>
                    <div class="absolute explore-svg explore-svg-3 bottom-0 top-0 w-[45%] pointer-events-none flex items-center">
                        <img src={aiSolutions} alt="" aria-hidden="true" class="w-full h-auto object-contain">
                    </div>
                </div>
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-4 h-[220px] sm:h-[240px] md:h-[260px]"
  data-aos="fade-up-sm"
  data-aos-delay="800"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content">
                        <h3>STEM for Girls</h3>
                        <p>I'm building resources to get young girls into tech before the world tells them not to.</p>
                    </div>
                    <div class="absolute explore-svg explore-svg-4 bottom-0 top-0 w-[45%] pointer-events-none flex items-center">
                        <img src={stemGirls} alt="" aria-hidden="true" class="w-full h-auto object-contain">
                    </div>
                </div>
                <div class="explore-item bg-bg-secondary/75 dark:bg-bg-secondary-dark relative overflow-hidden rounded-xl border border-primary/15 dark:border-neutral-700/50 explore-item-5 md:col-span-2 h-[220px] sm:h-[240px] md:h-[260px]"
  data-aos="fade-up-sm"
  data-aos-delay="900"
  data-aos-duration="600"
  data-aos-once="true">
                    <div class="content" style="max-width: 65%;">
                        <h3>Just for Fun</h3>
                        <p>Escape games, side projects, and whatever I built because I couldn't help myself.</p>
                    </div>
                    <div class="absolute explore-svg explore-svg-5 bottom-0 top-0 w-[45%] pointer-events-none flex items-center">
                        <img src={justForFun} alt="" aria-hidden="true" class="w-full h-auto object-contain">
                    </div>
                </div>

        </div>
    </div>
</section>

<style>
    .content{
        position: absolute;
        bottom: 0;
        left: 0;
        top: 0;
        max-width: 48%;
        padding-left:1rem;
        padding-right:0.5rem;
        display: flex;
        align-items: self-start;
        flex-direction: column;
        justify-content: center;
        transition: all 0.3s ease-in-out;
        z-index: 1;
    }


    @media (min-width: 640px) {
        .content {
            max-width: 48%;
            padding-left:1.25rem;
        }
    }

    @media (min-width: 768px) {
        .content {
            max-width: 50%;
            padding-left:1.5rem;
        }
    }

    .content h3{
        font-size: 1.25rem;
        line-height: 1.1;
        margin-bottom: 0.5rem;
        font-family: var(--font-brand);
    }

    @media (min-width: 640px) {
        .content h3 {
            font-size: 1.5rem;
        }
    }

    @media (min-width: 768px) {
        .content h3 {
            font-size: 1.75rem;
        }
    }

    .content p{
        font-size: 0.75rem;
        line-height: 1.3;
        font-weight: 400;
        color: var(--color-neutral-400);
        margin-bottom: 0;
    }
    .html .dark .content p{
        color: var(--color-neutral-300);
    }
    @media (min-width: 640px) {
        .content p {
            font-size: 0.8125rem;
        }
    }

    @media (min-width: 768px) {
        .content p {
            font-size: 0.875rem;
        }
    }

    .explore-item{
        position: relative;
        border-radius: 1rem;
        overflow: hidden;
        cursor: pointer;
        display: flex;
        justify-content: start;
        align-items: center;
    }
    .explore-item:hover .btn{
        opacity: 1;
    }


    .explore-svg {
        right: -8%;
        transition: right .5s ease-in-out;
        z-index: 10;
    }

    @media (min-width: 768px) {
        .explore-svg-5 {
            width: 22.5%;
        }
    }

    .explore-item-1:hover .explore-svg-1,
    .explore-item-2:hover .explore-svg-2,
    .explore-item-3:hover .explore-svg-3,
    .explore-item-4:hover .explore-svg-4,
    .explore-item-5:hover .explore-svg-5 {
        right: 0%;
    }

    @media (hover: none) {
        .explore-svg-1,
        .explore-svg-2,
        .explore-svg-3,
        .explore-svg-4,
        .explore-svg-5 {
            right: 0%;
        }
    }
</style>
