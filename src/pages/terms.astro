<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terms of Service — Ami Steelman</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500&family=Space+Mono&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --slate-deep: #1C2B3A;
      --slate-mid: #3D5A6B;
      --steel: #5B8FA8;
      --fog: #A8BCC8;
      --ice: #E8EEF2;
      --ink: #1C2B3A;
      --ink-secondary: #3D5A6B;
      --ink-tertiary: #7A96A6;
      --surface: #F4F7F9;
      --rule: #D6E2E9;
      --white: #ffffff;
    }

    html { font-size: 16px; }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 300;
      background: var(--surface);
      color: var(--ink);
      line-height: 1.8;
      min-height: 100vh;
    }

    header {
      border-bottom: 1px solid var(--rule);
      padding: 1.5rem 0;
      background: var(--white);
    }

    .container {
      max-width: 680px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .site-name {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 400;
      color: var(--ink);
      text-decoration: none;
      letter-spacing: -0.01em;
    }

    .site-name span {
      color: var(--steel);
      font-weight: 300;
    }

    main {
      padding: 4rem 0 6rem;
    }

    .page-label {
      font-size: 0.68rem;
      font-weight: 400;
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--steel);
      margin-bottom: 1rem;
    }

    h1 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: clamp(2rem, 5vw, 2.75rem);
      font-weight: 300;
      line-height: 1.15;
      letter-spacing: -0.025em;
      color: var(--ink);
      margin-bottom: 0.5rem;
    }

    .updated {
      font-size: 0.8rem;
      font-family: 'Space Mono', monospace;
      color: var(--ink-tertiary);
      margin-bottom: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid var(--rule);
    }

    .intro {
      font-size: 1rem;
      font-weight: 300;
      color: var(--ink-secondary);
      margin-bottom: 3rem;
      padding: 1.5rem;
      border-left: 2px solid var(--steel);
      background: rgba(91, 143, 168, 0.06);
      border-radius: 0 6px 6px 0;
    }

    section {
      margin-bottom: 2.5rem;
    }

    h2 {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.01em;
      color: var(--ink);
      margin-bottom: 0.75rem;
      padding-top: 2.5rem;
      border-top: 1px solid var(--rule);
    }

    section:first-of-type h2 {
      border-top: none;
      padding-top: 0;
    }

    p {
      color: var(--ink-secondary);
      margin-bottom: 1rem;
      font-size: 0.95rem;
      font-weight: 300;
    }

    p:last-child { margin-bottom: 0; }

    .contact-block {
      margin-top: 3rem;
      padding: 2rem;
      border: 1px solid var(--rule);
      border-radius: 8px;
      background: var(--white);
    }

    .contact-block p {
      margin-bottom: 0.5rem;
    }

    .contact-block a {
      color: var(--steel);
      text-decoration: none;
      font-weight: 400;
    }

    .contact-block a:hover {
      text-decoration: underline;
    }

    footer {
      border-top: 1px solid var(--rule);
      padding: 2rem 0;
      font-size: 0.75rem;
      font-family: 'Space Mono', monospace;
      color: var(--ink-tertiary);
      background: var(--white);
    }

    footer .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    footer a {
      color: var(--ink-tertiary);
      text-decoration: none;
    }

    footer a:hover { color: var(--ink); }

    @media (max-width: 480px) {
      .container { padding: 0 1.25rem; }
      main { padding: 2.5rem 0 4rem; }
      footer .container { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

  <header>
    <div class="container">
      <a href="/" class="site-name">ami<span>steelman</span></a>
    </div>
  </header>

  <main>
    <div class="container">

      <p class="page-label">// legal</p>
