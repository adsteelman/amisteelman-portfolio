    }

    h2 {
      font-family: 'Space Mono', monospace;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--steel);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.5rem;
    }

    p {
      font-size: 0.95rem;
      color: var(--ink-secondary);
    }

    footer {
      background: var(--slate-deep);
      color: var(--fog);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.85rem;
    }

    footer a {
